@startuml design

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

' ─────────────────────────────────────────────
'  ENUMS
' ─────────────────────────────────────────────
enum PlatformType {
  GITHUB
  GITLAB
}

enum ActivityType {
  COMMIT
  ISSUE
  PULL_REQUEST_REVIEW
}

enum IssueState {
  OPEN
  CLOSED
}

enum ReviewState {
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
}

enum Role {
  USER
  MANAGER
  ADMIN
}

enum ReportEventType {
  USER_REPORT
  COMPLETE
}

enum ReportType {
  ACTIVITY_LOG
  WEIGHTED_SCORE
}

enum TimePeriod {
  LAST_7_DAYS
  LAST_30_DAYS
  CURRENT_QUARTER
  LAST_QUARTER
  CURRENT_YEAR
  LAST_YEAR
  CUSTOM
}

' ─────────────────────────────────────────────
'  DOMAIN
'  Cross-aggregate references use String IDs.
'  Enums are value types; referencing them is fine.
' ─────────────────────────────────────────────
package Domain {

  class User {
    +id: String
    +username: String
    +displayName: String
    +email: String
    +avatarUrl: String
  }

  class UserAccount {
    +id: String
    +username: String
    +passwordHash: String
    +role: Role
    +userId: String
    +trackedRepositoryIds: List<String>
  }

  class Team {
    +id: String
    +name: String
    +managerId: String
    +memberIds: List<String>
  }

  class Repository {
    +id: String
    +name: String
    +fullName: String
    +url: String
    +platform: PlatformType
  }

  abstract class Activity {
    +id: String
    +url: String
    +createdAt: DateTime
    +authorId: String
    +repositoryId: String
    +{abstract} getType(): ActivityType
    +{abstract} getSummary(): String
  }

  class Commit extends Activity {
    +sha: String
    +message: String
    +additions: int
    +deletions: int
    +getType(): ActivityType
    +getSummary(): String
  }

  class Issue extends Activity {
    +title: String
    +body: String
    +state: IssueState
    +closedAt: DateTime
    +labels: List<String>
    +getType(): ActivityType
    +getSummary(): String
  }

  class PullRequestReview extends Activity {
    +pullRequestId: String
    +pullRequestTitle: String
    +state: ReviewState
    +body: String
    +submittedAt: DateTime
    +getType(): ActivityType
    +getSummary(): String
  }

  class BackupMetadata {
    +appVersion: String
    +exportedAt: DateTime
    +exportedBy: String
  }

  class BackupFile {
    +metadata: BackupMetadata
    +accounts: List<UserAccount>
    +teams: List<Team>
    +repositories: List<Repository>
  }

  ' Only enum references and internal composition remain
  UserAccount --> Role
  Repository  --> PlatformType
  BackupFile  --> BackupMetadata
}

' ─────────────────────────────────────────────
'  APPLICATION (USE CASES)
' ─────────────────────────────────────────────
package Application {

  ' ── Query / Report (moved from Domain) ───────

  class ActivityWeights {
    +commitWeight: double
    +issueWeight: double
    +reviewWeight: double
    +scoreFor(activities: List<Activity>): double
  }

  class ActivityQuery {
    +userIds: List<String>
    +repositoryIds: List<String>
    +activityTypes: List<ActivityType>
    +period: TimePeriod
    +since: DateTime
    +until: DateTime
    +reportType: ReportType
    +weights: ActivityWeights
  }

  class ReportSummary {
    +totalCount: int
    +countByUser: Map<String, int>
    +countByType: Map<ActivityType, int>
    +countByRepository: Map<String, int>
    +scoreByUser: Map<String, double>
  }

  class UserReport {
    +userId: String
    +activities: List<Activity>
    +summary: ReportSummary
    +weightedScore: double
  }

  class ActivityReport {
    +query: ActivityQuery
    +userReports: List<UserReport>
    +generatedAt: DateTime
    +getByType(type: ActivityType): List<Activity>
    +getSummary(): ReportSummary
  }

  ActivityQuery --> ActivityWeights
  ActivityQuery --> TimePeriod
  ActivityQuery --> ReportType
  UserReport "1" *-- "*" Domain.Activity
  UserReport --> ReportSummary
  ActivityReport --> ActivityQuery
  ActivityReport "1" *-- "*" UserReport
  ActivityReport --> ReportSummary : summary >

  ' ── Sources (Strategy + Registry) ───────────
  '
  ' Strategy: each ActivityFetcher declares what it can produce
  '   via getSupportedTypes() and getSupportedPlatforms().
  '   A single fetch() replaces the fixed per-type methods,
  '   so new contribution kinds never require interface changes.
  '
  ' Registry: ActivityFetcherRegistry is the extension point.
  '   New fetchers self-register; ActivityService queries the
  '   registry without knowing concrete implementations.

  interface ActivityFetcher {
    +getSupportedTypes(): Set<ActivityType>
    +getSupportedPlatforms(): Set<PlatformType>
    +fetch(userId: String, repositoryId: String, since: DateTime, until: DateTime): List<Activity>
  }

  class ActivityFetcherRegistry {
    +register(fetcher: ActivityFetcher): void
    +fetchersFor(platform: PlatformType, types: Set<ActivityType>): List<ActivityFetcher>
  }

  ActivityFetcherRegistry "1" o-- "*" ActivityFetcher : registered >

  ' ── Auth ─────────────────────────────────────

  class AuthToken {
    +value: String
    +expiresAt: DateTime
    +accountId: String
  }

  class AuthContext {
    +account: Domain.UserAccount
    +role: Role
    +teamId: String
    +isManager(): boolean
    +isAdmin(): boolean
    +canAccessUserId(userId: String): boolean
    +getAccessibleRepositoryIds(): List<String>
  }

  class AuthService {
    +login(username: String, password: String): AuthToken
    +logout(token: AuthToken): void
    +validate(token: AuthToken): AuthContext
  }

  ' ── Persistence ports ─────────────────────────

  interface UserAccountRepository {
    +findByUsername(username: String): UserAccount
    +findById(id: String): UserAccount
    +save(account: UserAccount): void
  }

  interface TeamRepository {
    +findByManagerId(managerId: String): Team
    +findByMemberId(memberId: String): Team
    +save(team: Team): void
  }

  interface UserRepository {
    +findById(id: String): User
    +findByIds(ids: List<String>): List<User>
  }

  interface RepositoryStore {
    +findById(id: String): Repository
    +findByIds(ids: List<String>): List<Repository>
  }

  AuthService --> UserAccountRepository  : reads >
  AuthService --> TeamRepository         : reads >
  AuthContext --> Domain.UserAccount

  ' ── Backup ───────────────────────────────────

  class BackupService {
    +exportBackup(auth: AuthContext): BackupFile
    +importBackup(auth: AuthContext, data: BackupFile): void
  }

  BackupService --> UserAccountRepository  : reads/writes >
  BackupService --> TeamRepository         : reads/writes >
  BackupService --> RepositoryStore        : reads/writes >
  BackupService ..> Domain.BackupFile      : produces/consumes >
  BackupService ..> AuthContext            : enforces ADMIN >

  ' ── Streaming events ─────────────────────────

  abstract class ReportEvent {
    +type: ReportEventType
  }

  class UserReportEvent extends ReportEvent {
    +userReport: UserReport
  }

  class ReportCompleteEvent extends ReportEvent {
    +summary: ReportSummary
  }

  class ActivityService {
    +streamActivities(query: ActivityQuery, auth: AuthContext): Stream<ReportEvent>
  }

  AuthService ..> AuthToken                   : issues >
  AuthService ..> AuthContext                 : produces >
  ReportEvent --> ReportEventType
  UserReportEvent --> UserReport
  ReportCompleteEvent --> ReportSummary
  ActivityService --> ActivityFetcherRegistry
  ActivityService --> UserRepository
  ActivityService --> RepositoryStore
  ActivityService ..> ReportEvent             : streams >
  ActivityService ..> AuthContext             : enforces >
}

' ─────────────────────────────────────────────
'  INFRASTRUCTURE
' ─────────────────────────────────────────────
package Infrastructure {

  ' Each fetcher is an independent Strategy implementation.
  ' Adding a new contribution kind = one new class + one register() call.

  class GitHubApiClient {
    -baseUrl: String
    -token: String
    +get(endpoint: String, params: Map): JsonNode
    +paginate(endpoint: String, params: Map): List<JsonNode>
  }

  class GitLabApiClient {
    -baseUrl: String
    -token: String
    +get(endpoint: String, params: Map): JsonNode
    +paginate(endpoint: String, params: Map): List<JsonNode>
  }

  class JiraApiClient {
    -baseUrl: String
    -token: String
    +get(endpoint: String, params: Map): JsonNode
  }

  class GitHubActivityFetcher implements Application.ActivityFetcher {
    -client: GitHubApiClient
    +getSupportedTypes(): Set<ActivityType>
    +getSupportedPlatforms(): Set<PlatformType>
    +fetch(userId: String, repositoryId: String, since: DateTime, until: DateTime): List<Activity>
  }

  class GitLabActivityFetcher implements Application.ActivityFetcher {
    -client: GitLabApiClient
    +getSupportedTypes(): Set<ActivityType>
    +getSupportedPlatforms(): Set<PlatformType>
    +fetch(userId: String, repositoryId: String, since: DateTime, until: DateTime): List<Activity>
  }

  class JiraActivityFetcher implements Application.ActivityFetcher {
    -client: JiraApiClient
    +getSupportedTypes(): Set<ActivityType>
    +getSupportedPlatforms(): Set<PlatformType>
    +fetch(userId: String, repositoryId: String, since: DateTime, until: DateTime): List<Activity>
  }

  GitHubActivityFetcher --> GitHubApiClient
  GitLabActivityFetcher --> GitLabApiClient
  JiraActivityFetcher   --> JiraApiClient

  class JpaUserAccountRepository implements Application.UserAccountRepository {
    +findByUsername(username: String): UserAccount
    +findById(id: String): UserAccount
    +save(account: UserAccount): void
  }

  class JpaTeamRepository implements Application.TeamRepository {
    +findByManagerId(managerId: String): Team
    +findByMemberId(memberId: String): Team
    +save(team: Team): void
  }

  class JpaUserRepository implements Application.UserRepository {
    +findById(id: String): User
    +findByIds(ids: List<String>): List<User>
  }

  class JpaRepositoryStore implements Application.RepositoryStore {
    +findById(id: String): Repository
    +findByIds(ids: List<String>): List<Repository>
  }

  GitHubSource --> GitHubApiClient
  GitLabSource --> GitLabApiClient
}

' ─────────────────────────────────────────────
'  PRESENTATION (Web API)
' ─────────────────────────────────────────────
package Presentation {

  class LoginController {
    -authService: AuthService
    +login(request: LoginRequest): LoginResponse
    +logout(token: String): void
  }

  class LoginRequest {
    +username: String
    +password: String
  }

  class LoginResponse {
    +token: String
    +expiresAt: String
    +role: String
  }

  class ReportEventDTO {
    +type: String
    +userReport: UserReportDTO
    +summary: SummaryDTO
  }

  class ActivityController {
    -activityService: ActivityService
    -authService: AuthService
    +streamReport(request: ReportRequest, token: String): SseStream<ReportEventDTO>
  }

  class ReportRequest {
    +usernames: List<String>
    +repositories: List<String>
    +platforms: List<String>
    +activityTypes: List<String>
    +period: String
    +since: String
    +until: String
    +reportType: String
    +commitWeight: double
    +issueWeight: double
    +reviewWeight: double
  }

  class UserReportDTO {
    +username: String
    +displayName: String
    +activities: List<ActivityDTO>
    +summary: SummaryDTO
    +weightedScore: double
  }

  class ActivityDTO {
    +type: String
    +id: String
    +url: String
    +summary: String
    +author: String
    +repository: String
    +createdAt: String
  }

  class SummaryDTO {
    +totalCount: int
    +countByUser: Map<String, int>
    +countByType: Map<String, int>
    +countByRepository: Map<String, int>
    +scoreByUser: Map<String, double>
  }

  class AdminController {
    -backupService: BackupService
    -authService: AuthService
    +exportBackup(token: String): ResponseEntity<BackupFile>
    +importBackup(token: String, file: MultipartFile): void
  }

  LoginController --> Application.AuthService
  LoginController ..> LoginRequest       : accepts >
  LoginController ..> LoginResponse      : returns >
  ActivityController --> Application.ActivityService
  ActivityController --> Application.AuthService
  ActivityController ..> ReportRequest   : accepts >
  ActivityController ..> ReportEventDTO  : streams >
  ReportEventDTO --> UserReportDTO
  ReportEventDTO --> SummaryDTO
  UserReportDTO "1" *-- "*" ActivityDTO
  UserReportDTO --> SummaryDTO
  AdminController --> Application.BackupService
  AdminController --> Application.AuthService
}

@enduml
